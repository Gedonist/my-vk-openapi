{
	"name": "my-vk-openapi",
	"description": "Cloudflare Worker for VK Callback API events with D1 logging and template replies.",
	"dependencies": {
		"chanfana": "2.8.3",
		"hono": "4.11.1",
		"zod": "3.25.67"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.11.1",
		"@types/node": "24.10.1",
		"@vitest/runner": "3.2.4",
		"@vitest/snapshot": "3.2.4",
		"typescript": "5.9.3",
		"vitest": "3.2.4",
		"wrangler": "4.88.0"
	},
	"private": true,
	"scripts": {
		"cf-typegen": "wrangler types",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"predeploy": "wrangler d1 migrations apply DB --remote",
		"schema": "npx chanfana",
		"migrate:local": "wrangler d1 migrations apply DB --local",
		"migrate:remote": "wrangler d1 migrations apply DB --remote",
		"test": "wrangler deploy --dry-run && npx vitest run --config tests/vitest.config.mts"
	}
}
